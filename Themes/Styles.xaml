<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- =============================== -->
    <!--        COLOR PALETTE           -->
    <!-- =============================== -->

    <!-- Warm parchment background -->
    <SolidColorBrush x:Key="ParchmentBrush" Color="#F7F4E9"/>

    <!-- Stone brown (primary UI color) -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#5A4637"/>

    <!-- Gold accent for borders + titles (BRUSH) -->
    <SolidColorBrush x:Key="GoldBrush" Color="#C9A856"/>

    <!-- Matching COLOR version for effects -->
    <Color x:Key="GoldColor">#C9A856</Color>

    <!-- Dark blue shadow / contrast color -->
    <SolidColorBrush x:Key="ShadowBrush" Color="#13293D"/>

    <!-- Light gold highlight -->
    <SolidColorBrush x:Key="HighlightBrush" Color="#E5D3A1"/>

    
    
    <!-- =============================== -->
    <!--           FONTS                -->
    <!-- =============================== -->
    <FontFamily x:Key="CinzelFont">./Fonts/#Cinzel</FontFamily>
    <FontFamily x:Key="CinzelBoldFont">./Fonts/#Cinzel Bold</FontFamily>
    <FontFamily x:Key="CinzelBlackFont">./Fonts/#Cinzel Black</FontFamily>


    <!-- =============================== -->
    <!--           TYPOGRAPHY           -->
    <!-- =============================== -->

    <!-- Default text style for all controls -->
    <Style TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
    </Style>

    <!-- Title text (Main menu title, puzzle names) -->
    <Style x:Key="TitleText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource CinzelBoldFont}"/>
        <Setter Property="FontSize" Value="42"/>
        <Setter Property="Foreground" Value="{StaticResource GoldBrush}"/>
        <Setter Property="TextAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0 20 0 20"/>
    </Style>

    <!-- Subtitle text -->
    <Style x:Key="SubtitleText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource CinzelFont}"/>
        <Setter Property="FontSize" Value="22"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
        <Setter Property="TextAlignment" Value="Center"/>
    </Style>


    <!-- ============================= -->
    <!--     ANCIENT GREEK BUTTON     -->
    <!-- ============================= -->

    <Style TargetType="Button" x:Key="GreekButton">
        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="Padding" Value="8 4"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Background" Value="#F0E6D2"/>
        <Setter Property="BorderBrush" Value="{StaticResource GoldBrush}"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">

                    <Grid>
                        <!-- Button background -->
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">

                            <!-- Inner shadow -->
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="6"
                                                  ShadowDepth="2"
                                                  Color="#60000000"
                                                  Opacity="0.4"/>
                            </Border.Effect>

                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </Grid>

                    <!-- Button states -->
                    <ControlTemplate.Triggers>

                        <!-- HOVER -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" 
                                    Value="#FFF4D7"/>
                            <Setter TargetName="border" Property="BorderBrush" 
                                    Value="{StaticResource HighlightBrush}"/>
                            <Setter TargetName="border" Property="Effect">
                                <Setter.Value>
                                    <!-- FIXED: Using GoldColor, not GoldBrush -->
                                    <DropShadowEffect Color="{StaticResource GoldColor}"
                                                      BlurRadius="12"
                                                      ShadowDepth="0"
                                                      Opacity="0.4"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>

                        <!-- PRESSED -->
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" 
                                    Value="#E6D9BC"/>
                            <Setter TargetName="border" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="Black"
                                                      BlurRadius="4"
                                                      ShadowDepth="1"
                                                      Opacity="0.5"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>

                        <!-- DISABLED -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================= -->
    <!--       GREEK TEXTBOX          -->
    <!-- ============================= -->

    <Style TargetType="TextBox" x:Key="GreekTextBox">
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
        <Setter Property="Background" Value="#FFF9E8"/>
        <Setter Property="BorderBrush" Value="{StaticResource GoldBrush}"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Padding" Value="6"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="6">

                        <!-- Inner engraved shadow -->
                        <Border.Effect>
                            <DropShadowEffect Color="#40000000"
                                          BlurRadius="6"
                                          ShadowDepth="2"
                                          Opacity="0.4"/>
                        </Border.Effect>

                        <ScrollViewer x:Name="PART_ContentHost"/>
                    </Border>

                    <ControlTemplate.Triggers>

                        <!-- FOCUSED (gold glow) -->
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="border" Property="BorderBrush"
                                Value="{StaticResource HighlightBrush}"/>
                            <Setter TargetName="border" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="{StaticResource GoldColor}"
                                                  BlurRadius="12"
                                                  ShadowDepth="0"
                                                  Opacity="0.6"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>

                        <!-- DISABLED -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                        </Trigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


</ResourceDictionary>
