<Window x:Class="TrialOfTheSphinx.UI.MemoryRoom"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chamber of Memory"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Width="800"
        Height="500"
        Background="{StaticResource ParchmentBrush}"
        Opacity="0">

    <!-- FADE-IN ON LOAD -->
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1"
                                     Duration="0:0:1.2"
                                     FillBehavior="HoldEnd"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <!-- ROOT GRID -->
    <Grid>

        <!-- VIGNETTE BACKGROUND -->
        <Rectangle Panel.ZIndex="0">
            <Rectangle.Fill>
                <RadialGradientBrush RadiusX="1.0" RadiusY="1.0"
                                     Center="0.5,0.5"
                                     GradientOrigin="0.5,0.5">
                    <GradientStop Color="#00000000" Offset="0.25"/>
                    <GradientStop Color="#AA000000" Offset="1.0"/>
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- BACKGROUND IMAGE -->
        <Image Source="../Images/Background.png"
               Stretch="UniformToFill"
               Opacity="0.55"
               Panel.ZIndex="1"/>

        <!-- MAIN UI GRID -->
        <Grid Panel.ZIndex="2" Margin="20">

            <!-- TIMER PROGRESS BAR AT TOP -->
            <ProgressBar Name="TimerBar"
                         Maximum="120"
                         Value="120"
                         Height="25"
                         Width="350"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Top"
                         Margin="0,15,0,0"/>

            <!-- CENTER AREA: COLOR BUTTONS + INDICATOR -->
            <Grid Width="280"
                  Height="280"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">

                <!-- 2x2 GRID OF COLORED BUTTONS -->
                <UniformGrid Name="ButtonGrid"
                             Rows="2"
                             Columns="2">

                    <Button Name="RedButton" Background="#A34A4A"/>
                    <Button Name="BlueButton" Background="#4F6D8A"/>
                    <Button Name="GreenButton" Background="#6FAF6F"/>
                    <Button Name="YellowButton" Background="#D4C66A"/>
                </UniformGrid>

                <!-- SEQUENCE INDICATOR IN MIDDLE -->
                <Ellipse Name="SequenceIndicator"
                         Width="90"
                         Height="90"
                         Fill="#666"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         Panel.ZIndex="10">
                    <Ellipse.Effect>
                        <DropShadowEffect Color="White"
                                          BlurRadius="25"
                                          ShadowDepth="0"
                                          Opacity="0.6"/>
                    </Ellipse.Effect>
                </Ellipse>

            </Grid>

            <!-- INVENTORY ICONS AT BOTTOM -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,20">
                <Image Name="Slot1" Width="45" Height="45" Source="/Images/slot.png" Margin="0,0,10,0"/>
                <Image Name="Slot2" Width="45" Height="45" Source="/Images/slot.png" Margin="0,0,10,0"/>
                <Image Name="Slot3" Width="45" Height="45" Source="/Images/slot.png"/>
            </StackPanel>

        </Grid>

    </Grid>

</Window>
