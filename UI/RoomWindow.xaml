<Window x:Class="TrialOfTheSphinx.UI.RoomWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Room"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Width="800"
        Height="500"
        Background="{StaticResource ParchmentBrush}"
        Opacity="0">

    <!-- FADE-IN -->
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1"
                                     Duration="0:0:1.2"
                                     FillBehavior="HoldEnd"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Grid>
        <!-- VIGNETTE -->
        <Rectangle Panel.ZIndex="0">
            <Rectangle.Fill>
                <RadialGradientBrush RadiusX="1.0" RadiusY="1.0"
                                     Center="0.5,0.5"
                                     GradientOrigin="0.5,0.5">
                    <GradientStop Color="#00000000" Offset="0.25"/>
                    <GradientStop Color="#AA000000" Offset="1.0"/>
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- BACKGROUND IMAGE -->
        <Image Source="../Images/Background.png"
               Stretch="UniformToFill"
               Opacity="0.55"
               Panel.ZIndex="1"/>

        <!-- MAIN UI -->
        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Width="500"
                    Panel.ZIndex="2">

            <TextBlock Name="RoomTitle"
                       Style="{StaticResource TitleText}"
                       Foreground="#FFFDF8"
                       Margin="0 0 0 10"
                       TextAlignment="Center">
                <TextBlock.Effect>
                    <DropShadowEffect Color="Black"
                                      BlurRadius="12"
                                      ShadowDepth="0"
                                      Opacity="0.7"/>
                </TextBlock.Effect>
            </TextBlock>

            <TextBlock Name="PuzzleQuestion"
                       Style="{StaticResource SubtitleText}"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       Margin="0 10 0 20"
                       Width="450"/>

            <TextBox Name="AnswerTextBox"
                     Style="{StaticResource GreekTextBox}"
                     FontSize="16"
                     Width="300"
                     Height="35"
                     Margin="0 0 0 15"/>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0 0 0 15">

                <Button Name="SubmitButton"
                        Style="{StaticResource GreekButton}"
                        Content="Submit Answer"
                        Width="160"
                        Height="40"
                        Margin="0 0 10 0"
                        Click="Submit_Click"/>

                <Button Style="{StaticResource GreekButton}"
                        Content="Get Hint"
                        Width="120"
                        Height="40"
                        Click="Hint_Click"/>

                <Button Name="NextRoomButton"
                        Style="{StaticResource GreekButton}"
                        Content="Next Room"
                        FontSize="16"
                        Width="150"
                        Click="NextRoomButton_Click"
                        IsEnabled="False"/>
            </StackPanel>

            <TextBlock x:Name="TimerText"
           Text="02:00"
           FontSize="18"
           FontWeight="Bold"
           HorizontalAlignment="Center"
           Margin="0,10,0,10" />


            <ProgressBar Name="TimerBar"
                         Height="25"
                         Maximum="120"
                         Value="120"
                         Width="450"
                         Margin="0 10 0 10"/>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0 15 0 0">

                <Image Name="Slot1" Width="40" Height="40"
                       Source="/Images/slot.png"
                       Margin="0 0 10 0"/>

                <Image Name="Slot2" Width="40" Height="40"
                       Source="/Images/slot.png"
                       Margin="0 0 10 0"/>

                <Image Name="Slot3" Width="40" Height="40"
                       Source="/Images/slot.png"/>
            </StackPanel>

        </StackPanel>

    </Grid>

</Window>
