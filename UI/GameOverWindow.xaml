<Window x:Class="TrialOfTheSphinx.UI.GameOverWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Game Over"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Width="800"
        Height="450"
        Background="{StaticResource ParchmentBrush}"
        Opacity="0">

    <!-- FADE-IN ANIMATION -->
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1"
                                     Duration="0:0:1.2"
                                     FillBehavior="HoldEnd"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="587*"/>
            <ColumnDefinition Width="19*"/>
            <ColumnDefinition Width="194*"/>
        </Grid.ColumnDefinitions>

        <!-- VIGNETTE OVERLAY -->
        <Rectangle Panel.ZIndex="0"
                   Grid.ColumnSpan="3">
            <Rectangle.Fill>
                <RadialGradientBrush RadiusX="1.0" RadiusY="1.0"
                                     Center="0.5,0.5"
                                     GradientOrigin="0.5,0.5">
                    <GradientStop Color="#00000000" Offset="0.25"/>
                    <GradientStop Color="#CC000000" Offset="1.0"/>
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- OPTIONAL BACKGROUND IMAGE -->
        <Image Source="../Images/Background.png"
               Stretch="UniformToFill"
               Opacity="0.55"
               Panel.ZIndex="1"
               Grid.ColumnSpan="3"/>

        <!-- MAIN CONTENT -->
        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Left"
                    Width="450"
                    Panel.ZIndex="2"
                    Grid.ColumnSpan="3"
                    Margin="175,0,0,0">

            <TextBlock Text="Game Over"
                       Style="{StaticResource TitleText}"
                       Foreground="#FFFDF8">
                <TextBlock.Effect>
                    <DropShadowEffect Color="Black"
                                      BlurRadius="15"
                                      ShadowDepth="0"
                                      Opacity="0.7"/>
                </TextBlock.Effect>
            </TextBlock>

            <TextBlock Text="You failed to escape the temple. Better luck next time!"
                       Style="{StaticResource SubtitleText}"
                       Margin="0 10 0 20"
                       TextWrapping="Wrap"
                       Width="350"/>

            <Button Style="{StaticResource GreekButton}"
                    Content="Main Menu"
                    Width="200"
                    Height="45"
                    Margin="0 10 0 10"
                    Click="MainMenu_Click"/>

            <Button Style="{StaticResource GreekButton}"
                    Content="Exit"
                    Width="200"
                    Height="45"
                    Click="Exit_Click"/>

        </StackPanel>

    </Grid>

</Window>

